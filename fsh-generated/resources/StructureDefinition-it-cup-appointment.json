{
  "resourceType": "StructureDefinition",
  "id": "it-cup-appointment",
  "url": "https://www.fhir.laziocrea.it/StructureDefinition/it-cup-appointment",
  "name": "ITCUPAppointment",
  "title": "IT CUP Appointment - Prenotazione",
  "status": "draft",
  "experimental": true,
  "description": "Profilo italiano per la risorsa Appointment nel contesto CUP.\nRappresenta la prenotazione di una prestazione ambulatoriale.\n\nRelazioni:\n- basedOn → ITCUPServiceRequest (impegnativa SSN)\n- slot    → ITCUPSlot (fascia oraria prenotata)\n- participant → Patient (assistito), Practitioner (professionista),\n                Location (sede di erogazione)\n\nEstensioni italiane:\n- Codice prenotazione CUP (numero consegnato all'utente)\n- Canale di prenotazione (sportello, telefono, web...)\n- Classe di priorità CUP (U/B/D/P)\n- Modalità di erogazione (in presenza / teleconsulto)\n- Link teleconsulto (URL sessione video, se applicabile)",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Appointment",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Appointment",
  "derivation": "constraint",
