{
  "resourceType": "StructureDefinition",
  "id": "it-cup-service-request",
  "url": "https://www.fhir.laziocrea.it/StructureDefinition/it-cup-service-request",
  "name": "ITCUPServiceRequest",
  "title": "IT CUP ServiceRequest - Impegnativa SSN",
  "status": "draft",
  "experimental": true,
  "description": "Profilo italiano per la risorsa ServiceRequest nel contesto CUP.\nRappresenta l'impegnativa dematerializzata o cartacea del medico\nprescrittore (MMG, PLS o specialista), necessaria per prenotare\nuna prestazione ambulatoriale in regime SSN.\n\nRelazioni:\n- referenziata da Appointment.basedOn\n- emessa da Practitioner (MMG/PLS/Specialista)\n- destinata a Patient (Assistito)\n- il codice prestazione fa riferimento al Nomenclatore Nazionale",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "ServiceRequest",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/ServiceRequest",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "ServiceRequest.extension",
        "path": "ServiceRequest.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        }
      },
      {
        "id": "ServiceRequest.extension:classePrioritaCup",
        "path": "ServiceRequest.extension",
        "sliceName": "classePrioritaCup",
        "short": "Classe priorità CUP: U, B, D o P",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://www.fhir.laziocrea.it/StructureDefinition/ext-classe-priorita-cup"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.identifier",
        "path": "ServiceRequest.identifier",
        "short": "NRE (Numero Ricetta Elettronica) o codice impegnativa",
        "definition": "L'NRE è il numero univoco assegnato all'impegnativa dematerializzata\ndal sistema TS (Tessera Sanitaria) del MEF. Per le ricette cartacee\nsi usa il codice a barre.",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.status",
        "path": "ServiceRequest.status",
        "short": "Stato: active | completed | cancelled | on-hold",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.intent",
        "path": "ServiceRequest.intent",
        "short": "Sempre 'order': è un ordine del medico",
        "patternCode": "order",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.priority",
        "path": "ServiceRequest.priority",
        "short": "Priorità FHIR (routine | urgent | asap | stat)",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.code",
        "path": "ServiceRequest.code",
        "short": "Codice prestazione (Nomenclatore Nazionale/Regionale)",
        "definition": "Codice della prestazione secondo il Nomenclatore Tariffario Nazionale\n(DM 18/10/2012 e aggiornamenti) o il nomenclatore regionale.\nEsempi:\n- 89.7  Visita medica generale\n- 88.74 Ecografia addome\n- 89.52 Elettrocardiogramma",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.quantity[x]",
        "path": "ServiceRequest.quantity[x]",
        "slicing": {
          "discriminator": [
            {
              "type": "type",
              "path": "$this"
            }
          ],
          "ordered": false,
          "rules": "open"
        },
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.quantity[x]:quantityQuantity",
        "path": "ServiceRequest.quantity[x]",
        "sliceName": "quantityQuantity",
        "short": "Numero di prestazioni prescritte (es. 3 sedute fisioterapia)",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Quantity"
          }
        ]
      },
      {
        "id": "ServiceRequest.subject",
        "path": "ServiceRequest.subject",
        "short": "Assistito per cui è prescritta la prestazione",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/StructureDefinition/Patient"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.authoredOn",
        "path": "ServiceRequest.authoredOn",
        "short": "Data di emissione dell'impegnativa",
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.requester",
        "path": "ServiceRequest.requester",
        "short": "MMG, PLS o specialista che ha emesso l'impegnativa",
        "min": 1,
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/StructureDefinition/Practitioner",
              "http://hl7.org/fhir/StructureDefinition/PractitionerRole"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "ServiceRequest.reasonCode",
        "path": "ServiceRequest.reasonCode",
        "short": "Quesito diagnostico o indicazione clinica",
        "mustSupport": true
      }
    ]
  }
}
