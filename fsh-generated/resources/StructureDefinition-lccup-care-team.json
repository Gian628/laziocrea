{
  "resourceType": "StructureDefinition",
  "id": "lccup-care-team",
  "url": "https://www.fhir.laziocrea.it/StructureDefinition/lccup-care-team",
  "name": "LcCupCareTeam",
  "title": "LcCup CareTeam - Equipe teleconsulto",
  "status": "draft",
  "experimental": true,
  "description": "Equipe associata ad agende e appuntamenti teleconsulto IRT.\nOgni membro è un Practitioner con ruolo in equipe (medico, infermiere, amministrativo).",
  "fhirVersion": "5.0.0",
  "kind": "resource",
  "abstract": false,
  "type": "CareTeam",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/CareTeam",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "CareTeam.status",
        "path": "CareTeam.status",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "CareTeam.name",
        "path": "CareTeam.name",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "CareTeam.participant",
        "path": "CareTeam.participant",
        "short": "Membri dell'equipe (solo Practitioner)",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "CareTeam.participant.role",
        "path": "CareTeam.participant.role",
        "min": 1,
        "mustSupport": true,
        "binding": {
          "strength": "required",
          "valueSet": "https://www.fhir.laziocrea.it/ValueSet/vs-ruolo-equipe"
        }
      },
      {
        "id": "CareTeam.participant.member",
        "path": "CareTeam.participant.member",
        "min": 1,
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/StructureDefinition/Practitioner"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "CareTeam.managingOrganization",
        "path": "CareTeam.managingOrganization",
        "short": "Struttura gestore dell'equipe",
        "min": 1,
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://www.fhir.laziocrea.it/StructureDefinition/lccup-organization"
            ]
          }
        ],
        "mustSupport": true
      }
    ]
  }
}
