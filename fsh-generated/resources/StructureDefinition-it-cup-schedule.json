{
  "resourceType": "StructureDefinition",
  "id": "it-cup-schedule",
  "url": "https://www.fhir.laziocrea.it/StructureDefinition/it-cup-schedule",
  "name": "ITCUPSchedule",
  "title": "IT CUP Schedule - Agenda",
  "status": "draft",
  "experimental": true,
  "description": "Profilo italiano per la risorsa Schedule nel contesto CUP.\nRappresenta un'agenda ambulatoriale prenotabile tramite il\nCentro Unico di Prenotazione. Ogni agenda ha un tipo (SSN/ALPI/privato),\nun erogatore, una sede fisica e un orizzonte temporale di pianificazione.\n\nRelazioni:\n- contiene molti Slot (fasce orarie libere/occupate)\n- è associata a HealthcareService, Practitioner e/o Location",
  "fhirVersion": "4.0.1",
  "kind": "resource",
  "abstract": false,
  "type": "Schedule",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Schedule",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Schedule.extension",
        "path": "Schedule.extension",
        "slicing": {
          "discriminator": [
            {
              "type": "value",
              "path": "url"
            }
          ],
          "ordered": false,
          "rules": "open"
        },
        "min": 1
      },
      {
        "id": "Schedule.extension:tipoAgenda",
        "path": "Schedule.extension",
        "sliceName": "tipoAgenda",
        "short": "Tipo agenda: SSN, ALPI, Privata o Convenzionata",
        "min": 1,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://www.fhir.laziocrea.it/StructureDefinition/ext-tipo-agenda"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Schedule.extension:modalitaErogazione",
        "path": "Schedule.extension",
        "sliceName": "modalitaErogazione",
        "short": "Modalità di erogazione: in presenza, teleconsulto o telemonitoraggio",
        "min": 0,
        "max": "1",
        "type": [
          {
            "code": "Extension",
            "profile": [
              "https://www.fhir.laziocrea.it/StructureDefinition/ext-modalita-erogazione"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Schedule.identifier",
        "path": "Schedule.identifier",
        "short": "Codice agenda nel sistema CUP",
        "definition": "Identificatore univoco dell'agenda nel sistema CUP regionale.\nDeve essere presente almeno un identifier con il codice assegnato\ndal sistema informativo regionale.",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Schedule.active",
        "path": "Schedule.active",
        "short": "L'agenda è attiva e prenotabile",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Schedule.serviceType",
        "path": "Schedule.serviceType",
        "short": "Tipo di prestazione erogata (es. Cardiologia, Ecografia...)",
        "min": 1,
        "mustSupport": true
      },
      {
        "id": "Schedule.specialty",
        "path": "Schedule.specialty",
        "short": "Specialità medica dell'agenda",
        "mustSupport": true
      },
      {
        "id": "Schedule.actor",
        "path": "Schedule.actor",
        "short": "Erogatore: professionista, servizio e/o sede fisica",
        "definition": "Risorsa a cui l'agenda appartiene. Nel contesto CUP devono essere\npresenti almeno:\n- HealthcareService: il servizio/ambulatorio erogante\n- Location: la sede fisica dove si eroga la prestazione\nUn'agenda può avere anche un Practitioner specifico associato.",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "http://hl7.org/fhir/StructureDefinition/Practitioner",
              "http://hl7.org/fhir/StructureDefinition/PractitionerRole",
              "http://hl7.org/fhir/StructureDefinition/HealthcareService",
              "http://hl7.org/fhir/StructureDefinition/Location"
            ]
          }
        ],
        "mustSupport": true
      },
      {
        "id": "Schedule.planningHorizon",
        "path": "Schedule.planningHorizon",
        "short": "Periodo di validità dell'agenda (da - a)",
        "mustSupport": true
      },
      {
        "id": "Schedule.comment",
        "path": "Schedule.comment",
        "short": "Note sull'agenda (es. 'Primo accesso', 'Solo anziani')",
        "mustSupport": true
      }
    ]
  }
}
